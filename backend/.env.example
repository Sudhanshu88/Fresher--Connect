S3_BUCKET=
AWS_REGION=
S3_ENDPOINT_URL=
S3_PREFIX=uploads
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=240
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX=20
