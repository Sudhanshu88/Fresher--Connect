# Separate backend container example. Replace the Mongo URI and allowed frontend domains before deploy.
BACKEND_PORT=5000
SECRET_KEY=change-this-before-production
JWT_SECRET_KEY=change-this-before-production
SESSION_COOKIE_SECURE=true
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/fresher_connect?retryWrites=true&w=majority
MONGODB_USE_MOCK=false
MAX_CONTENT_LENGTH=10485760
FRONTEND_ORIGINS=https://freshersconnect.net,https://www.freshersconnect.net
DISABLE_SEED_DATA=true
STORAGE_BACKEND=local
S3_BUCKET=
AWS_REGION=
S3_ENDPOINT_URL=
S3_PREFIX=uploads
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=240
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
